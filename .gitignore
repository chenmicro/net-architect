# Installed by `npm install` in mcp/doc-fetcher — reproducible from
# package.json/package-lock.json, not meant to be version-controlled.
node_modules/

# npm's crash log from a failed install/run; local debugging noise only.
npm-debug.log*

# Finder's per-directory metadata cache on macOS; contributor-machine-specific.
.DS_Store

# Holds real API keys (BRAVE_API_KEY, FIRECRAWL_API_KEY); never commit secrets.
# Copy .env.example to .env and fill in your own values.
.env
