# Copy to .env and fill in the keys you have. Both are optional — the
# doc-fetcher MCP server (mcp/doc-fetcher) falls back to no-key behavior
# (DuckDuckGo HTML search, raw HTTP fetch) when a key is missing.

# Brave Search API key — used by search_web instead of the DuckDuckGo HTML
# fallback, which is frequently blocked by anti-bot challenges from
# server/cloud IPs. Get one at https://brave.com/search/api/
BRAVE_API_KEY=

# Firecrawl API key — used by fetch_doc to render JS pages before extracting
# text, instead of a raw HTTP GET. Get one at https://www.firecrawl.dev/
FIRECRAWL_API_KEY=
